# App Settings
APP_HOST=0.0.0.0
APP_PORT=8001
SECRET_KEY=change_this_to_a_random_secret_key

# MongoDB
# ─ Khi chạy docker-compose (network_mode: host) → dùng localhost:28017
# ─ Khi chạy bridge network → đổi thành mongodb://mongodb:28017
MONGODB_URL=mongodb://localhost:28017
MONGODB_DB_NAME=face_recognition
MONGODB_PORT=28017

# InsightFace Settings
INSIGHTFACE_MODEL=buffalo_s
FACE_THRESHOLD=0.45
FACE_IMAGES_DIR=./face_images

# Finger Reader service
FINGER_READER_URL=http://localhost:8082
